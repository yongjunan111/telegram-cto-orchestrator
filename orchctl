#!/usr/bin/env python3
"""orchctl — minimal CLI for managing orchestrator rooms and handoffs."""

import argparse
import sys

from lib.rooms import cmd_room_create, cmd_room_list, cmd_room_show, cmd_room_memory, cmd_room_contract, cmd_room_discovery
from lib.readiness import cmd_room_readiness
from lib.handoffs import (
    cmd_handoff_create, cmd_handoff_list, cmd_handoff_show,
    cmd_handoff_claim, cmd_handoff_block, cmd_handoff_complete,
    cmd_handoff_brief, cmd_handoff_room_memory, cmd_handoff_review,
    cmd_handoff_approve, cmd_handoff_request_changes,
    cmd_handoff_rework,
)
from lib.log import cmd_log_append
from lib.sessions import cmd_session_list, cmd_session_show, cmd_session_upsert
from lib.dispatch import cmd_handoff_dispatch_plan, cmd_handoff_dispatch
from lib.checkpoints import cmd_session_checkpoint
from lib.bootstrap import cmd_session_bootstrap
from lib.pipeline import cmd_task_run
from lib.init import cmd_init
from lib.doctor import cmd_doctor
from lib.peers import cmd_peer_add, cmd_peer_list, cmd_peer_show, cmd_peer_remove, cmd_peer_update
from lib.wiki_suggest import cmd_handoff_wiki_suggest


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="orchctl",
        description="Minimal CLI for managing orchestrator rooms.",
    )
    sub = parser.add_subparsers(dest="command", metavar="<command>")
    sub.required = True

    # room subcommand
    room_p = sub.add_parser("room", help="Room management commands")
    room_sub = room_p.add_subparsers(dest="room_command", metavar="<subcommand>")
    room_sub.required = True

    # room create
    create_p = room_sub.add_parser("create", help="Create a new room")
    create_p.add_argument("room_id", metavar="<room-id>")
    create_p.add_argument("--name", required=True, help="Human-readable room name")
    create_p.add_argument("--goal", required=True, help="Room goal description")
    create_p.set_defaults(func=cmd_room_create)

    # room list
    list_p = room_sub.add_parser("list", help="List all rooms")
    list_p.set_defaults(func=cmd_room_list)

    # room show
    show_p = room_sub.add_parser("show", help="Show room state")
    show_p.add_argument("room_id", metavar="<room-id>")
    show_p.set_defaults(func=cmd_room_show)

    # room memory
    rmem_p = room_sub.add_parser("memory", help="Update room memory fields")
    rmem_p.add_argument("room_id", metavar="<room-id>")
    rmem_p.add_argument("--request-summary", default=None, dest="request_summary",
                        help="Set request summary (replaces current value)")
    rmem_p.add_argument("--current-summary", default=None, dest="current_summary",
                        help="Set current summary (replaces current value)")
    rmem_p.add_argument("--next-action", default=None, dest="next_action",
                        help="Set next action (replaces current value)")
    rmem_p.add_argument("--blocker-summary", default=None, dest="blocker_summary",
                        help="Set blocker summary (replaces current value)")
    rmem_p.add_argument("--blocked-by", default=None, dest="blocked_by",
                        help="Set blocked-by value (replaces current value)")
    rmem_p.add_argument("--open-question", action="append", default=None, dest="open_questions",
                        help="Set open questions (repeatable; replaces entire list)")
    rmem_p.add_argument("--clear-open-questions", action="store_true", default=False,
                        dest="clear_open_questions",
                        help="Clear all open questions")
    rmem_p.add_argument("--clear-blocker", action="store_true", default=False,
                        dest="clear_blocker",
                        help="Clear blocker_summary and blocked_by")
    rmem_p.add_argument("--phase", default=None,
                        help="Set room phase (e.g., triage, planning, execution, review, done)")
    rmem_p.add_argument("--execution-cwd", default=None, dest="execution_cwd",
                        help="Set worker execution directory (required for dispatch)")
    rmem_p.set_defaults(func=cmd_room_memory)

    # room contract
    rcontract_p = room_sub.add_parser("contract", help="Update room-level contract (constraints, acceptance criteria)")
    rcontract_p.add_argument("room_id", metavar="<room-id>")
    rcontract_p.add_argument("--constraint", action="append", default=None, dest="constraints",
                             help="Set room constraint (repeatable; replaces entire list)")
    rcontract_p.add_argument("--acceptance-criterion", action="append", default=None, dest="acceptance_criteria",
                             help="Set room acceptance criterion (repeatable; replaces entire list)")
    rcontract_p.add_argument("--clear-constraints", action="store_true", default=False,
                             dest="clear_constraints",
                             help="Clear all room constraints")
    rcontract_p.add_argument("--clear-acceptance-criteria", action="store_true", default=False,
                             dest="clear_acceptance_criteria",
                             help="Clear all room acceptance criteria")
    rcontract_p.set_defaults(func=cmd_room_contract)

    # room discovery
    rdisc_p = room_sub.add_parser("discovery", help="Update room discovery/planning artifacts")
    rdisc_p.add_argument("room_id", metavar="<room-id>")

    # Scalar fields
    rdisc_p.add_argument("--problem-statement", default=None, dest="problem_statement")
    rdisc_p.add_argument("--chosen-direction", default=None, dest="chosen_direction")
    rdisc_p.add_argument("--readiness-notes", default=None, dest="readiness_notes")

    # List fields (repeatable, replace semantics)
    rdisc_p.add_argument("--confirmed-fact", action="append", default=None, dest="confirmed_facts")
    rdisc_p.add_argument("--assumption", action="append", default=None, dest="assumptions")
    rdisc_p.add_argument("--option", action="append", default=None, dest="options_considered")
    rdisc_p.add_argument("--decision", action="append", default=None, dest="decisions_made")
    rdisc_p.add_argument("--dependency", action="append", default=None, dest="dependencies")
    rdisc_p.add_argument("--implementation-unknown", action="append", default=None, dest="implementation_unknowns")

    # Clear flags
    rdisc_p.add_argument("--clear-confirmed-facts", action="store_true", default=False, dest="clear_confirmed_facts")
    rdisc_p.add_argument("--clear-assumptions", action="store_true", default=False, dest="clear_assumptions")
    rdisc_p.add_argument("--clear-options", action="store_true", default=False, dest="clear_options")
    rdisc_p.add_argument("--clear-decisions", action="store_true", default=False, dest="clear_decisions")
    rdisc_p.add_argument("--clear-dependencies", action="store_true", default=False, dest="clear_dependencies")
    rdisc_p.add_argument("--clear-implementation-unknowns", action="store_true", default=False, dest="clear_unknowns")
    rdisc_p.add_argument("--clear-problem-statement", action="store_true", default=False, dest="clear_problem_statement")
    rdisc_p.add_argument("--clear-chosen-direction", action="store_true", default=False, dest="clear_chosen_direction")
    rdisc_p.add_argument("--clear-readiness-notes", action="store_true", default=False, dest="clear_readiness_notes")

    rdisc_p.set_defaults(func=cmd_room_discovery)

    # room readiness
    rready_p = room_sub.add_parser("readiness", help="Assess room readiness for next action")
    rready_p.add_argument("room_id", metavar="<room-id>")
    rready_p.set_defaults(func=cmd_room_readiness)

    # log subcommand
    log_p = sub.add_parser("log", help="Log management commands")
    log_sub = log_p.add_subparsers(dest="log_command", metavar="<subcommand>")
    log_sub.required = True

    # log append
    append_p = log_sub.add_parser("append", help="Append entry to room log")
    append_p.add_argument("room_id", metavar="<room-id>")
    append_p.add_argument("--actor", required=True, help="Actor name")
    append_p.add_argument("--message", required=True, help="Log message")
    append_p.set_defaults(func=cmd_log_append)

    # handoff subcommand
    handoff_p = sub.add_parser("handoff", help="Handoff management commands")
    handoff_sub = handoff_p.add_subparsers(dest="handoff_command", metavar="<subcommand>")
    handoff_sub.required = True

    # handoff create
    hcreate_p = handoff_sub.add_parser("create", help="Create a new handoff")
    hcreate_p.add_argument("handoff_id", metavar="<handoff-id>")
    hcreate_p.add_argument("--room", required=True, help="Target room ID")
    hcreate_p.add_argument("--to", required=True, help="Target peer ID")
    hcreate_p.add_argument("--task", required=True, help="Task description")
    hcreate_p.add_argument("--priority", default="medium",
                           choices=["critical", "high", "medium", "low"],
                           help="Priority (default: medium)")
    hcreate_p.add_argument("--scope", default="", help="Scope of the work")
    hcreate_p.add_argument("--report-back", default="", dest="report_back",
                           help="Where/how to report results")
    hcreate_p.add_argument("--non-goal", action="append", default=None, dest="non_goals",
                           help="What must NOT be done (repeatable)")
    hcreate_p.add_argument("--invariant", action="append", default=None, dest="invariants",
                           help="Property that must be preserved (repeatable)")
    hcreate_p.add_argument("--failure-example", action="append", default=None, dest="failure_examples",
                           help="Concrete example of what failure looks like (repeatable)")
    hcreate_p.add_argument("--validation", action="append", default=None, dest="validation",
                           help="Verification step to perform after implementation (repeatable)")
    hcreate_p.add_argument("--constraint", action="append", default=None, dest="constraints",
                           help="Task constraint (repeatable)")
    hcreate_p.add_argument("--acceptance-criterion", action="append", default=None, dest="acceptance_criteria",
                           help="Task acceptance criterion (repeatable)")
    hcreate_p.add_argument("--kind", default="implementation", choices=["implementation", "discovery"],
                           help="Handoff kind (default: implementation)")
    hcreate_p.set_defaults(func=cmd_handoff_create)

    # handoff list
    hlist_p = handoff_sub.add_parser("list", help="List all handoffs")
    hlist_p.add_argument("--room", default=None, help="Filter handoffs by room ID")
    hlist_p.set_defaults(func=cmd_handoff_list)

    # handoff show
    hshow_p = handoff_sub.add_parser("show", help="Show handoff details")
    hshow_p.add_argument("handoff_id", metavar="<handoff-id>")
    hshow_p.set_defaults(func=cmd_handoff_show)

    # handoff claim
    hclaim_p = handoff_sub.add_parser("claim", help="Claim a handoff")
    hclaim_p.add_argument("handoff_id", metavar="<handoff-id>")
    hclaim_p.add_argument("--by", required=True, help="Peer ID claiming the handoff")
    hclaim_p.set_defaults(func=cmd_handoff_claim)

    # handoff block
    hblock_p = handoff_sub.add_parser("block", help="Block a claimed handoff")
    hblock_p.add_argument("handoff_id", metavar="<handoff-id>")
    hblock_p.add_argument("--by", required=True, help="Peer ID blocking the handoff")
    hblock_p.add_argument("--reason", required=True, help="Reason for blocking")
    hblock_p.set_defaults(func=cmd_handoff_block)

    # handoff complete
    hcomplete_p = handoff_sub.add_parser("complete", help="Complete a claimed handoff")
    hcomplete_p.add_argument("handoff_id", metavar="<handoff-id>")
    hcomplete_p.add_argument("--by", required=True, help="Peer ID completing the handoff")
    hcomplete_p.add_argument("--summary", required=True, help="Completion summary")
    hcomplete_p.add_argument("--file", action="append", default=None, dest="files",
                             help="File created or modified (repeatable)")
    hcomplete_p.add_argument("--verification", action="append", default=None, dest="verifications",
                             help="Verification step performed (repeatable)")
    hcomplete_p.add_argument("--risk", action="append", default=None, dest="risks",
                             help="Remaining risk or deferred item (repeatable)")
    hcomplete_p.add_argument("--validation-cover", action="append", default=None, dest="validation_covers",
                             help="Cover a validation step: '<index>:<evidence>' (1-based, repeatable)")
    hcomplete_p.add_argument("--task-criterion-cover", action="append", default=None, dest="task_criterion_covers",
                             help="Cover task acceptance criterion: '<index>:<evidence>' (1-based, repeatable)")
    hcomplete_p.add_argument("--room-criterion-cover", action="append", default=None, dest="room_criterion_covers",
                             help="Cover room acceptance criterion: '<index>:<evidence>' (1-based, repeatable)")
    hcomplete_p.set_defaults(func=cmd_handoff_complete)

    # handoff brief
    hbrief_p = handoff_sub.add_parser("brief", help="Generate worker execution brief")
    hbrief_p.add_argument("handoff_id", metavar="<handoff-id>")
    hbrief_p.set_defaults(func=cmd_handoff_brief)

    # handoff room-memory
    hrmem_p = handoff_sub.add_parser("room-memory", help="Suggest room memory updates from handoff result")
    hrmem_p.add_argument("handoff_id", metavar="<handoff-id>")
    hrmem_p.set_defaults(func=cmd_handoff_room_memory)

    # handoff review
    hreview_p = handoff_sub.add_parser("review", help="Review completion evidence for a completed handoff")
    hreview_p.add_argument("handoff_id", metavar="<handoff-id>")
    hreview_p.set_defaults(func=cmd_handoff_review)

    # handoff approve
    happrove_p = handoff_sub.add_parser("approve", help="Approve a completed handoff")
    happrove_p.add_argument("handoff_id", metavar="<handoff-id>")
    happrove_p.add_argument("--by", required=True, help="Reviewer peer ID")
    happrove_p.add_argument("--note", default=None, help="Optional approval note")
    happrove_p.set_defaults(func=cmd_handoff_approve)

    # handoff request-changes
    hreqch_p = handoff_sub.add_parser("request-changes", help="Request changes on a completed handoff")
    hreqch_p.add_argument("handoff_id", metavar="<handoff-id>")
    hreqch_p.add_argument("--by", required=True, help="Reviewer peer ID")
    hreqch_p.add_argument("--note", required=True, help="What changes are needed")
    hreqch_p.add_argument("--must-address", action="append", required=True, dest="must_address",
                          help="Required change item (repeatable, at least one required)")
    hreqch_p.set_defaults(func=cmd_handoff_request_changes)

    # handoff rework
    hrework_p = handoff_sub.add_parser("rework", help="Create rework handoff from changes_requested review")
    hrework_p.add_argument("handoff_id", metavar="<handoff-id>")
    hrework_p.add_argument("--by", required=True, help="Peer requesting the rework")
    hrework_p.add_argument("--to", default=None, help="Assignee for rework (defaults to original assignee)")
    hrework_p.set_defaults(func=cmd_handoff_rework)

    # handoff dispatch-plan
    hdispatch_p = handoff_sub.add_parser("dispatch-plan", help="Derived dispatch allocation recommendation")
    hdispatch_p.add_argument("handoff_id", metavar="<handoff-id>")
    hdispatch_p.set_defaults(func=cmd_handoff_dispatch_plan)

    # handoff dispatch
    hdisp_p = handoff_sub.add_parser("dispatch", help="Execute handoff dispatch (tmux + session state)")
    hdisp_p.add_argument("handoff_id", metavar="<handoff-id>")
    hdisp_p.set_defaults(func=cmd_handoff_dispatch)

    # handoff wiki-suggest
    hwiki_p = handoff_sub.add_parser("wiki-suggest", help="Suggest wiki updates from handoff cycle")
    hwiki_p.add_argument("handoff_id", metavar="<handoff-id>")
    hwiki_p.set_defaults(func=cmd_handoff_wiki_suggest)

    # session subcommand
    session_p = sub.add_parser("session", help="Runtime session state commands")
    session_sub = session_p.add_subparsers(dest="session_command", metavar="<subcommand>")
    session_sub.required = True

    # session list
    slist_p = session_sub.add_parser("list", help="List all sessions")
    slist_p.set_defaults(func=cmd_session_list)

    # session show
    sshow_p = session_sub.add_parser("show", help="Show session details")
    sshow_p.add_argument("session_id", metavar="<session-id>")
    sshow_p.set_defaults(func=cmd_session_show)

    # session upsert
    supsert_p = session_sub.add_parser("upsert", help="Create or update session state")
    supsert_p.add_argument("session_id", metavar="<session-id>")
    supsert_p.add_argument("--peer-id", default=None, dest="peer_id")
    supsert_p.add_argument("--tmux-session", default=None, dest="tmux_session")
    supsert_p.add_argument("--tmux-target", default=None, dest="tmux_target",
                           help="Exact tmux pane id (e.g. %%12) — required for new dispatches to be reusable")
    supsert_p.add_argument("--mode", default=None, choices=["ephemeral", "warm", "persistent"])
    supsert_p.add_argument("--status", default=None, choices=["offline", "idle", "busy"])
    supsert_p.add_argument("--room-id", default=None, dest="room_id")
    supsert_p.add_argument("--handoff-id", default=None, dest="handoff_id")
    supsert_p.add_argument("--cwd", default=None)
    supsert_p.add_argument("--branch", default=None)
    supsert_p.add_argument("--dirty", default=None, help="true|false")
    supsert_p.add_argument("--reuse-count", default=None, dest="reuse_count")
    supsert_p.add_argument("--heartbeat-at", default=None, dest="heartbeat_at")
    supsert_p.add_argument("--lease-until", default=None, dest="lease_until")
    supsert_p.add_argument("--last-active-at", default=None, dest="last_active_at")
    supsert_p.set_defaults(func=cmd_session_upsert)

    # session checkpoint
    scheck_p = session_sub.add_parser("checkpoint", help="Create derived session checkpoint artifact")
    scheck_p.add_argument("session_id", metavar="<session-id>")
    scheck_p.add_argument("--event", required=True, help="Checkpoint event name (e.g. manual-checkpoint, shell-exit)")
    scheck_p.add_argument("--note", default=None, help="Optional note")
    scheck_p.set_defaults(func=cmd_session_checkpoint)

    # session bootstrap
    sboot_p = session_sub.add_parser("bootstrap", help="Create derived session bootstrap artifact")
    sboot_p.add_argument("session_id", metavar="<session-id>")
    sboot_p.set_defaults(func=cmd_session_bootstrap)

    # task subcommand
    task_p = sub.add_parser("task", help="Task automation commands")
    task_sub = task_p.add_subparsers(dest="task_command", metavar="<subcommand>")
    task_sub.required = True

    # task run
    trun_p = task_sub.add_parser("run", help="Create room + handoff + dispatch in one step")
    trun_p.add_argument("--message", required=True, help="Task description / message")
    trun_p.add_argument("--cwd", required=True, help="Worker execution directory")
    trun_p.add_argument("--peer", default=None, help="Target peer ID (default: worker-1)")
    trun_p.add_argument("--priority", default="medium",
                        choices=["critical", "high", "medium", "low"],
                        help="Priority (default: medium)")
    trun_p.set_defaults(func=cmd_task_run)

    # init subcommand
    init_p = sub.add_parser("init", help="Initialize orchestrator directory structure")
    init_p.set_defaults(func=cmd_init)

    # doctor subcommand
    doctor_p = sub.add_parser("doctor", help="Check environment and configuration health")
    doctor_p.set_defaults(func=cmd_doctor)

    # peer subcommand
    peer_p = sub.add_parser("peer", help="Peer management commands")
    peer_sub = peer_p.add_subparsers(dest="peer_command", metavar="<subcommand>")
    peer_sub.required = True

    # peer add
    padd_p = peer_sub.add_parser("add", help="Register a new peer")
    padd_p.add_argument("peer_id", metavar="<peer-id>")
    padd_p.add_argument("--name", default=None, help="Human-readable peer name")
    padd_p.add_argument("--type", default="worker", choices=["worker", "reviewer", "specialist"],
                        dest="peer_type", help="Peer type (default: worker)")
    padd_p.add_argument("--cwd", default=None, help="Peer working directory")
    padd_p.add_argument("--capabilities", default=None,
                        help="Comma-separated list of capabilities")
    padd_p.set_defaults(func=cmd_peer_add)

    # peer list
    plist_p = peer_sub.add_parser("list", help="List all peers")
    plist_p.set_defaults(func=cmd_peer_list)

    # peer show
    pshow_p = peer_sub.add_parser("show", help="Show peer details")
    pshow_p.add_argument("peer_id", metavar="<peer-id>")
    pshow_p.set_defaults(func=cmd_peer_show)

    # peer remove
    premove_p = peer_sub.add_parser("remove", help="Remove a peer")
    premove_p.add_argument("peer_id", metavar="<peer-id>")
    premove_p.set_defaults(func=cmd_peer_remove)

    # peer update
    pupdate_p = peer_sub.add_parser("update", help="Update peer attributes")
    pupdate_p.add_argument("peer_id", metavar="<peer-id>")
    pupdate_p.add_argument("--name", default=None, help="Human-readable peer name")
    pupdate_p.add_argument("--type", default=None, choices=["worker", "reviewer", "specialist"],
                           dest="peer_type", help="Peer type")
    pupdate_p.add_argument("--cwd", default=None, help="Peer working directory")
    pupdate_p.add_argument("--status", default=None, choices=["available", "busy", "offline"],
                           help="Peer status")
    pupdate_p.add_argument("--capabilities", default=None,
                           help="Comma-separated list of capabilities")
    pupdate_p.set_defaults(func=cmd_peer_update)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
