#!/usr/bin/env python3
"""orchctl — minimal CLI for managing orchestrator rooms and handoffs."""

import argparse
import sys

from lib.rooms import cmd_room_create, cmd_room_list, cmd_room_show, cmd_room_memory, cmd_room_contract
from lib.handoffs import (
    cmd_handoff_create, cmd_handoff_list, cmd_handoff_show,
    cmd_handoff_claim, cmd_handoff_block, cmd_handoff_complete,
    cmd_handoff_brief, cmd_handoff_room_memory, cmd_handoff_review,
    cmd_handoff_approve, cmd_handoff_request_changes,
    cmd_handoff_rework,
)
from lib.log import cmd_log_append


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="orchctl",
        description="Minimal CLI for managing orchestrator rooms.",
    )
    sub = parser.add_subparsers(dest="command", metavar="<command>")
    sub.required = True

    # room subcommand
    room_p = sub.add_parser("room", help="Room management commands")
    room_sub = room_p.add_subparsers(dest="room_command", metavar="<subcommand>")
    room_sub.required = True

    # room create
    create_p = room_sub.add_parser("create", help="Create a new room")
    create_p.add_argument("room_id", metavar="<room-id>")
    create_p.add_argument("--name", required=True, help="Human-readable room name")
    create_p.add_argument("--goal", required=True, help="Room goal description")
    create_p.set_defaults(func=cmd_room_create)

    # room list
    list_p = room_sub.add_parser("list", help="List all rooms")
    list_p.set_defaults(func=cmd_room_list)

    # room show
    show_p = room_sub.add_parser("show", help="Show room state")
    show_p.add_argument("room_id", metavar="<room-id>")
    show_p.set_defaults(func=cmd_room_show)

    # room memory
    rmem_p = room_sub.add_parser("memory", help="Update room memory fields")
    rmem_p.add_argument("room_id", metavar="<room-id>")
    rmem_p.add_argument("--request-summary", default=None, dest="request_summary",
                        help="Set request summary (replaces current value)")
    rmem_p.add_argument("--current-summary", default=None, dest="current_summary",
                        help="Set current summary (replaces current value)")
    rmem_p.add_argument("--next-action", default=None, dest="next_action",
                        help="Set next action (replaces current value)")
    rmem_p.add_argument("--blocker-summary", default=None, dest="blocker_summary",
                        help="Set blocker summary (replaces current value)")
    rmem_p.add_argument("--blocked-by", default=None, dest="blocked_by",
                        help="Set blocked-by value (replaces current value)")
    rmem_p.add_argument("--open-question", action="append", default=None, dest="open_questions",
                        help="Set open questions (repeatable; replaces entire list)")
    rmem_p.add_argument("--clear-open-questions", action="store_true", default=False,
                        dest="clear_open_questions",
                        help="Clear all open questions")
    rmem_p.add_argument("--clear-blocker", action="store_true", default=False,
                        dest="clear_blocker",
                        help="Clear blocker_summary and blocked_by")
    rmem_p.add_argument("--phase", default=None,
                        help="Set room phase (e.g., triage, planning, execution, review, done)")
    rmem_p.set_defaults(func=cmd_room_memory)

    # room contract
    rcontract_p = room_sub.add_parser("contract", help="Update room-level contract (constraints, acceptance criteria)")
    rcontract_p.add_argument("room_id", metavar="<room-id>")
    rcontract_p.add_argument("--constraint", action="append", default=None, dest="constraints",
                             help="Set room constraint (repeatable; replaces entire list)")
    rcontract_p.add_argument("--acceptance-criterion", action="append", default=None, dest="acceptance_criteria",
                             help="Set room acceptance criterion (repeatable; replaces entire list)")
    rcontract_p.add_argument("--clear-constraints", action="store_true", default=False,
                             dest="clear_constraints",
                             help="Clear all room constraints")
    rcontract_p.add_argument("--clear-acceptance-criteria", action="store_true", default=False,
                             dest="clear_acceptance_criteria",
                             help="Clear all room acceptance criteria")
    rcontract_p.set_defaults(func=cmd_room_contract)

    # log subcommand
    log_p = sub.add_parser("log", help="Log management commands")
    log_sub = log_p.add_subparsers(dest="log_command", metavar="<subcommand>")
    log_sub.required = True

    # log append
    append_p = log_sub.add_parser("append", help="Append entry to room log")
    append_p.add_argument("room_id", metavar="<room-id>")
    append_p.add_argument("--actor", required=True, help="Actor name")
    append_p.add_argument("--message", required=True, help="Log message")
    append_p.set_defaults(func=cmd_log_append)

    # handoff subcommand
    handoff_p = sub.add_parser("handoff", help="Handoff management commands")
    handoff_sub = handoff_p.add_subparsers(dest="handoff_command", metavar="<subcommand>")
    handoff_sub.required = True

    # handoff create
    hcreate_p = handoff_sub.add_parser("create", help="Create a new handoff")
    hcreate_p.add_argument("handoff_id", metavar="<handoff-id>")
    hcreate_p.add_argument("--room", required=True, help="Target room ID")
    hcreate_p.add_argument("--to", required=True, help="Target peer ID")
    hcreate_p.add_argument("--task", required=True, help="Task description")
    hcreate_p.add_argument("--priority", default="medium",
                           choices=["critical", "high", "medium", "low"],
                           help="Priority (default: medium)")
    hcreate_p.add_argument("--scope", default="", help="Scope of the work")
    hcreate_p.add_argument("--report-back", default="", dest="report_back",
                           help="Where/how to report results")
    hcreate_p.add_argument("--non-goal", action="append", default=None, dest="non_goals",
                           help="What must NOT be done (repeatable)")
    hcreate_p.add_argument("--invariant", action="append", default=None, dest="invariants",
                           help="Property that must be preserved (repeatable)")
    hcreate_p.add_argument("--failure-example", action="append", default=None, dest="failure_examples",
                           help="Concrete example of what failure looks like (repeatable)")
    hcreate_p.add_argument("--validation", action="append", default=None, dest="validation",
                           help="Verification step to perform after implementation (repeatable)")
    hcreate_p.add_argument("--constraint", action="append", default=None, dest="constraints",
                           help="Task constraint (repeatable)")
    hcreate_p.add_argument("--acceptance-criterion", action="append", default=None, dest="acceptance_criteria",
                           help="Task acceptance criterion (repeatable)")
    hcreate_p.set_defaults(func=cmd_handoff_create)

    # handoff list
    hlist_p = handoff_sub.add_parser("list", help="List all handoffs")
    hlist_p.add_argument("--room", default=None, help="Filter handoffs by room ID")
    hlist_p.set_defaults(func=cmd_handoff_list)

    # handoff show
    hshow_p = handoff_sub.add_parser("show", help="Show handoff details")
    hshow_p.add_argument("handoff_id", metavar="<handoff-id>")
    hshow_p.set_defaults(func=cmd_handoff_show)

    # handoff claim
    hclaim_p = handoff_sub.add_parser("claim", help="Claim a handoff")
    hclaim_p.add_argument("handoff_id", metavar="<handoff-id>")
    hclaim_p.add_argument("--by", required=True, help="Peer ID claiming the handoff")
    hclaim_p.set_defaults(func=cmd_handoff_claim)

    # handoff block
    hblock_p = handoff_sub.add_parser("block", help="Block a claimed handoff")
    hblock_p.add_argument("handoff_id", metavar="<handoff-id>")
    hblock_p.add_argument("--by", required=True, help="Peer ID blocking the handoff")
    hblock_p.add_argument("--reason", required=True, help="Reason for blocking")
    hblock_p.set_defaults(func=cmd_handoff_block)

    # handoff complete
    hcomplete_p = handoff_sub.add_parser("complete", help="Complete a claimed handoff")
    hcomplete_p.add_argument("handoff_id", metavar="<handoff-id>")
    hcomplete_p.add_argument("--by", required=True, help="Peer ID completing the handoff")
    hcomplete_p.add_argument("--summary", required=True, help="Completion summary")
    hcomplete_p.add_argument("--file", action="append", default=None, dest="files",
                             help="File created or modified (repeatable)")
    hcomplete_p.add_argument("--verification", action="append", default=None, dest="verifications",
                             help="Verification step performed (repeatable)")
    hcomplete_p.add_argument("--risk", action="append", default=None, dest="risks",
                             help="Remaining risk or deferred item (repeatable)")
    hcomplete_p.add_argument("--validation-cover", action="append", default=None, dest="validation_covers",
                             help="Cover a validation step: '<index>:<evidence>' (1-based, repeatable)")
    hcomplete_p.set_defaults(func=cmd_handoff_complete)

    # handoff brief
    hbrief_p = handoff_sub.add_parser("brief", help="Generate worker execution brief")
    hbrief_p.add_argument("handoff_id", metavar="<handoff-id>")
    hbrief_p.set_defaults(func=cmd_handoff_brief)

    # handoff room-memory
    hrmem_p = handoff_sub.add_parser("room-memory", help="Suggest room memory updates from handoff result")
    hrmem_p.add_argument("handoff_id", metavar="<handoff-id>")
    hrmem_p.set_defaults(func=cmd_handoff_room_memory)

    # handoff review
    hreview_p = handoff_sub.add_parser("review", help="Review completion evidence for a completed handoff")
    hreview_p.add_argument("handoff_id", metavar="<handoff-id>")
    hreview_p.set_defaults(func=cmd_handoff_review)

    # handoff approve
    happrove_p = handoff_sub.add_parser("approve", help="Approve a completed handoff")
    happrove_p.add_argument("handoff_id", metavar="<handoff-id>")
    happrove_p.add_argument("--by", required=True, help="Reviewer peer ID")
    happrove_p.add_argument("--note", default=None, help="Optional approval note")
    happrove_p.set_defaults(func=cmd_handoff_approve)

    # handoff request-changes
    hreqch_p = handoff_sub.add_parser("request-changes", help="Request changes on a completed handoff")
    hreqch_p.add_argument("handoff_id", metavar="<handoff-id>")
    hreqch_p.add_argument("--by", required=True, help="Reviewer peer ID")
    hreqch_p.add_argument("--note", required=True, help="What changes are needed")
    hreqch_p.add_argument("--must-address", action="append", required=True, dest="must_address",
                          help="Required change item (repeatable, at least one required)")
    hreqch_p.set_defaults(func=cmd_handoff_request_changes)

    # handoff rework
    hrework_p = handoff_sub.add_parser("rework", help="Create rework handoff from changes_requested review")
    hrework_p.add_argument("handoff_id", metavar="<handoff-id>")
    hrework_p.add_argument("--by", required=True, help="Peer requesting the rework")
    hrework_p.add_argument("--to", default=None, help="Assignee for rework (defaults to original assignee)")
    hrework_p.set_defaults(func=cmd_handoff_rework)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
